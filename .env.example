# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NUXT_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-your-key
NUXT_OPENROUTER_API_KEY=sk-or-v1-your-key

# Amazon SES (Email)
NUXT_AMAZON_SES_IAM_USER=your-iam-user
NUXT_AMAZON_EMAIL_FROM=FocusFlow <noreply@tudominio.com>
NUXT_AMAZON_SMTP_ENDPOINT=email-smtp.us-east-1.amazonaws.com
NUXT_AMAZON_SMTP_PORT=587
NUXT_AMAZON_SMTP_USER=your-ses-smtp-user
NUXT_AMAZON_SMTP_PASSWORD=your-ses-smtp-password

# Cron Secret (for deadline checker)
NUXT_CRON_SECRET=random-secret-here

# Firebase (Push Notifications)
NUXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NUXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NUXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key
NUXT_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
